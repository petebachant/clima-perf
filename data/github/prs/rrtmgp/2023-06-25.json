  {
    "additions": 9,
    "author": {
      "id": "MDQ6VXNlcjE4ODA2NDE=",
      "is_bot": false,
      "login": "charleskawczynski",
      "name": "Charles Kawczynski"
    },
    "body": "Based on the flame graphs, we seem to be hitting this slow path (https://stackoverflow.com/questions/14687665/very-slow-stdpow-for-bases-very-close-to-1), same as what we hit in thermodynamics.\r\n\r\nThis PR adds `pow_fast(x, y) = exp(y * log(x))` to avoid the slow path.",
    "changedFiles": 4,
    "closingIssuesReferences": [],
